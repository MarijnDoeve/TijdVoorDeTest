# define your env variables for the test env here
KERNEL_CLASS='Tvdt\Kernel'
APP_SECRET='$ecretf0rt3st'
MAILER_DSN=null://null
MAILER_SENDER=test@example.org

###> symfony/panther ###
# Reuse the "test" env (and its _test-suffixed database, see config/packages/doctrine.yaml)
# instead of the recipe's default separate "panther" env, so E2E tests share the same
# isolated database as the rest of the test suite. Reset it with `just reload-tests` before
# running `just test-e2e` — DAMA's per-test rollback doesn't cover Panther's separate browser
# process, so state persists across E2E test runs within one invocation.
PANTHER_APP_ENV=test
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots
PANTHER_DEVTOOLS=0
###< symfony/panther ###
